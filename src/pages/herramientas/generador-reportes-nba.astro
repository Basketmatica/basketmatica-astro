---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import heroImg from '../../assets/blog/generador-de-reportes-de-la-nba/dfb0583a-a603-47b4-b8f9-5f7c319cbdb6.webp';

const title = 'Generador de Reportes de la NBA';
const description =
  'Herramienta gratuita: introduce el nombre de un jugador de la NBA y obtén un scouting report en PDF con datos avanzados y análisis de IA.';
---
<BaseLayout title={title} description={description} image={heroImg.src}>
  <article class="generador">
    <p class="post-meta"><a href="/herramientas/">Herramientas</a> / {title}</p>

    <Image
      class="hero-img"
      src={heroImg}
      alt="Generador de Reportes de la NBA"
      widths={[480, 760, 1080]}
      sizes="(max-width: 760px) 100vw, 760px"
    />

    <h1>{title}</h1>

    <div class="prose">
      <p>
        <strong>Generador de Reportes NBA</strong>: una herramienta gratuita para analistas, entrenadores y
        aficionados. Introduce el nombre de cualquier jugador de la NBA y obtendrás un informe detallado en PDF con:
      </p>
      <ul>
        <li><strong>Datos básicos y perfil del jugador.</strong></li>
        <li><strong>Estadísticas actuales e históricas</strong>, métricas simples y compuestas.</li>
        <li><strong>Análisis FODA</strong> (Fortalezas, Oportunidades, Debilidades y Amenazas) respaldado por métricas avanzadas.</li>
        <li><strong>Comparación con jugadores de perfil y trayectorias similares.</strong></li>
      </ul>
    </div>

    <!-- Formulario -->
    <section class="report-form-container">
      <h2>Genera tu reporte</h2>
      <form id="pdf-form">
        <label for="playerName">Nombre del jugador</label>
        <input
          type="text"
          id="playerName"
          name="playerName"
          placeholder="Ej. Stephen Curry"
          autocomplete="off"
          required
        />
        <button type="submit" id="gen-btn">Generar PDF</button>

        <!-- Estado de carga -->
        <div id="status-area" class="status-area" hidden>
          <div class="hex-spinner" aria-hidden="true">
            <svg viewBox="0 0 40 46" xmlns="http://www.w3.org/2000/svg" width="28" height="32">
              <path
                d="M20 2 L38 12 L38 34 L20 44 L2 34 L2 12 Z"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-dasharray="132"
                stroke-dashoffset="132"
              />
            </svg>
          </div>
          <p id="status" role="status" aria-live="polite"></p>
        </div>

        <!-- Resultado / error -->
        <p id="result" role="alert" aria-live="assertive" class="result-msg" hidden></p>
      </form>
    </section>

    <p class="example-report">
      ¿Quieres ver cómo queda antes de generarlo?
      <a href="/files/pau-gasol-report-1.pdf" download>Descarga el ejemplo real de Pau Gasol</a>.
    </p>

    <div class="tips">
      <p class="tips-title">Consejos de uso</p>
      <ul>
        <li>Escribe el nombre completo del jugador: <em>LeBron James</em>, <em>Nikola Jokić</em>, <em>Marc Gasol</em>.</li>
        <li>Nombres con caracteres especiales (<em>Luka Dončić</em>, <em>Dražen Petrović</em>) deben incluirlos.</li>
        <li>La primera generación puede tardar hasta 20 segundos mientras el servidor se activa.</li>
      </ul>
    </div>

    <p class="note">
      <strong>Nota sobre la IA:</strong> Los informes se generan mediante modelos de IA. El contenido analítico
      mantiene rigor, aunque pueden existir pequeñas variaciones de formato entre generaciones.
    </p>
  </article>
</BaseLayout>

<style>
  .generador { max-width: 760px; margin-inline: auto; }
  .generador h1 { margin-top: 1.2rem; }

  /* Form container */
  .report-form-container {
    max-width: 520px;
    margin: 2.5rem auto;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  .report-form-container h2 { margin: 0 0 1.2rem; text-align: center; }
  .report-form-container label {
    display: block;
    margin-bottom: .4rem;
    font-weight: 600;
    font-family: var(--font-display);
  }
  .report-form-container input[type='text'] {
    width: 100%;
    padding: .65rem .9rem;
    margin-bottom: 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--bg);
    color: var(--ink);
    box-sizing: border-box;
  }
  .report-form-container input[type='text']:focus {
    outline: 2px solid var(--accent);
    border-color: var(--accent);
  }
  #gen-btn {
    width: 100%;
    padding: .75rem;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background .2s, transform .15s;
  }
  #gen-btn:hover:not(:disabled) { background: var(--accent-600); transform: scale(1.01); }
  #gen-btn:disabled { background: var(--line); color: var(--ink-soft); cursor: not-allowed; transform: none; }

  /* Loading state */
  .status-area {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-top: 1.2rem;
  }
  .status-area[hidden] { display: none; }

  .hex-spinner { color: var(--accent); flex-shrink: 0; }
  .hex-spinner svg path {
    animation: hexdraw 1.4s ease-in-out infinite;
  }
  @keyframes hexdraw {
    0%   { stroke-dashoffset: 132; opacity: .3; }
    50%  { stroke-dashoffset: 0;   opacity: 1;  }
    100% { stroke-dashoffset: -132; opacity: .3; }
  }

  #status { margin: 0; font-size: .9rem; color: var(--ink-soft); }

  /* Result message */
  .result-msg {
    margin-top: 1rem;
    font-size: .92rem;
    padding: .7rem 1rem;
    border-radius: 8px;
    border-left: 3px solid var(--accent);
    background: var(--surface);
  }
  .result-msg[hidden] { display: none; }
  .result-msg.error { border-left-color: #c0392b; color: #c0392b; }
  .result-msg.success { border-left-color: var(--accent); color: var(--accent-600); }

  /* Example */
  .example-report { font-size: .93rem; text-align: center; margin-top: -.5rem; }

  /* Tips */
  .tips {
    margin: 2rem 0;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: .91rem;
  }
  .tips-title { font-family: var(--font-display); font-weight: 700; margin: 0 0 .5rem; color: var(--brand); font-size: .9rem; }
  .tips ul { margin: 0; padding-left: 1.3rem; color: var(--ink-soft); line-height: 1.7; }

  /* AI note */
  .note {
    font-size: .91rem;
    background: var(--surface);
    padding: 1rem;
    border-left: 4px solid var(--brand);
    border-radius: 6px;
    color: var(--ink-soft);
  }
</style>

<script>
  const API = 'https://reportgeneratornba.onrender.com';

  const form      = document.getElementById('pdf-form') as HTMLFormElement | null;
  const btn       = document.getElementById('gen-btn') as HTMLButtonElement | null;
  const input     = document.getElementById('playerName') as HTMLInputElement | null;
  const statusEl  = document.getElementById('status') as HTMLParagraphElement | null;
  const statusArea = document.getElementById('status-area') as HTMLElement | null;
  const resultEl  = document.getElementById('result') as HTMLParagraphElement | null;

  function setStatus(msg: string) {
    if (statusEl) statusEl.textContent = msg;
  }

  function setResult(msg: string, type: 'success' | 'error') {
    if (!resultEl) return;
    resultEl.textContent = msg;
    resultEl.className = `result-msg ${type}`;
    resultEl.hidden = false;
  }

  function resetResult() {
    if (resultEl) { resultEl.hidden = true; resultEl.textContent = ''; resultEl.className = 'result-msg'; }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const playerName = input?.value.trim() ?? '';
    if (!playerName) return;

    btn!.disabled = true;
    if (statusArea) statusArea.hidden = false;
    resetResult();

    try {
      setStatus('Activando servidor… (primera vez puede tardar ~15 s)');
      await fetch(`${API}/`).catch(() => {});
      await new Promise((r) => setTimeout(r, 5000));

      setStatus('Servidor activo. Generando informe…');
      const response = await fetch(
        `${API}/generate-pdf/?player_name=${encodeURIComponent(playerName)}`
      );

      if (!response.ok) {
        let message = 'Error al generar el PDF. Inténtalo de nuevo.';
        try {
          const err = await response.json();
          if (err.detail) message = err.detail;
        } catch {
          if (response.status === 404)
            message = `Jugador "${playerName}" no encontrado. Verifica el nombre (incluye caracteres especiales si los hay) e inténtalo de nuevo.`;
          else if (response.status === 500)
            message = 'Error interno del servidor. Espera unos minutos e inténtalo de nuevo.';
          else if (response.status === 429)
            message = 'Demasiadas peticiones. Espera unos segundos e inténtalo de nuevo.';
        }
        throw new Error(message);
      }

      setStatus('Preparando descarga…');
      const blob = await response.blob();
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = `${playerName}_Report.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);

      setResult('Informe generado y descargado correctamente.', 'success');
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Error desconocido. Inténtalo de nuevo.';
      setResult(msg, 'error');
    } finally {
      btn!.disabled = false;
      if (statusArea) statusArea.hidden = true;
      setStatus('');
    }
  });
</script>
