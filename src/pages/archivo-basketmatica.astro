---
<BaseLayout wide title={title} description={description} image={heroImage?.src}>
  <article class="archivo">
    <h1>{title}</h1>

    {heroImage && (
      <Image
        class="hero-img"
        src={heroImage}
        alt={heroAlt || title}
        widths={[480, 760, 1080]}
        sizes="(max-width: 1080px) 100vw, 1080px"
      />
    )}

    <p class="intro">
      Recopilación de todos los hilos publicados en <a href="https://x.com/basketmatica">X&nbsp;(@basketmatica)</a>,
      organizados por tema. Guárdalo en favoritos y úsalo como referencia cuando necesites profundizar en una métrica.
    </p>

    <!-- Leyenda -->
    <div class="legend">
      {LEGEND.map(({ emoji, label }) => (
        <span class="legend-item"><span aria-hidden="true">{emoji}</span> {label}</span>
      ))}
    </div>

    <!-- Controles de filtro -->
    <div class="arch-controls">
      <input
        id="arch-search"
        type="search"
        placeholder="Buscar hilo…"
        aria-label="Buscar en el archivo"
      />
      <div class="arch-filters" role="group" aria-label="Filtrar por tema">
        <button class="filter-btn active" data-filter="" aria-pressed="true">Todos</button>
        {LEGEND.map(({ emoji }) => (
          <button class="filter-btn" data-filter={emoji} aria-pressed="false">{emoji}</button>
        ))}
      </div>
    </div>

    <p id="arch-count" class="arch-count" aria-live="polite">{threads.length} hilos</p>

    <!-- Grid de hilos -->
    <div id="arch-grid" class="arch-grid">
      {threads.map((t) => (
        <a
          class="thread-card"
          href={t.url}
          data-tema={t.tema}
          data-titulo={t.titulo.toLowerCase()}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="thread-emoji" aria-hidden="true">{t.tema}</span>
          <span class="thread-fecha">{t.fecha}</span>
          <h2 class="thread-titulo">{t.titulo}</h2>
          <span class="thread-cta">Ver hilo →</span>
        </a>
      ))}
    </div>

    <p id="arch-empty" class="arch-empty" hidden>No hay resultados para esa búsqueda.</p>
  </article>
</BaseLayout>

<style>
  .archivo { padding-block: 1rem 3rem; }
  .archivo h1 { margin-bottom: 1rem; }

  .intro { color: var(--ink-soft); font-size: 1.05rem; margin: .5rem 0 1.5rem; max-width: 700px; }

  /* Legend */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem 1.2rem;
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: .9rem;
  }
  .legend-item { display: flex; align-items: center; gap: .35rem; color: var(--ink-soft); }

  /* Controls */
  .arch-controls {
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: .8rem;
  }
  #arch-search {
    flex: 1;
    min-width: 200px;
    padding: .55rem .9rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--surface);
    color: var(--ink);
  }
  #arch-search:focus { outline: 2px solid var(--accent); border-color: var(--accent); }

  .arch-filters { display: flex; gap: .4rem; flex-wrap: wrap; }
  .filter-btn {
    padding: .35rem .8rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--ink-soft);
    font-size: .88rem;
    font-family: var(--font-display);
    font-weight: 500;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
  }
  .filter-btn:hover { border-color: var(--brand); color: var(--brand); }
  .filter-btn.active { background: var(--brand); border-color: var(--brand); color: #fff; }

  .arch-count { font-size: .85rem; color: var(--ink-soft); margin: 0 0 1rem; font-family: var(--font-mono); }

  /* Thread grid */
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .thread-card {
    display: flex;
    flex-direction: column;
    gap: .3rem;
    padding: 1.1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color .18s, box-shadow .18s;
  }
  .thread-card:hover { border-color: var(--brand); box-shadow: var(--shadow); }
  .thread-card[hidden] { display: none; }

  .thread-emoji { font-size: 1.5rem; line-height: 1; }
  .thread-fecha { font-family: var(--font-mono); font-size: .76rem; color: var(--ink-soft); margin-top: .15rem; }
  .thread-titulo { font-family: var(--font-display); font-size: .98rem; font-weight: 600; color: var(--brand); margin: .2rem 0 .3rem; line-height: 1.35; }
  .thread-cta { font-size: .82rem; font-family: var(--font-display); font-weight: 600; color: var(--accent-600); margin-top: auto; }
  .thread-card:hover .thread-cta { color: var(--accent); }

  .arch-empty { text-align: center; color: var(--ink-soft); padding: 3rem 0; font-size: 1.05rem; }

  @media (max-width: 500px) {
    .arch-controls { flex-direction: column; align-items: stretch; }
    #arch-search { min-width: 0; }
  }
</style>

<script>
  const searchEl = document.getElementById('arch-search') as HTMLInputElement | null;
  const countEl  = document.getElementById('arch-count') as HTMLParagraphElement | null;
  const emptyEl  = document.getElementById('arch-empty') as HTMLParagraphElement | null;
  const cards    = document.querySelectorAll<HTMLElement>('.thread-card');
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');

  let activeFilter = '';

  function applyFilters() {
    const q = (searchEl?.value ?? '').toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const tema   = card.dataset.tema ?? '';
      const titulo = card.dataset.titulo ?? '';
      const matchFilter = !activeFilter || tema === activeFilter;
      const matchSearch = !q || titulo.includes(q);
      const show = matchFilter && matchSearch;
      card.hidden = !show;
      if (show) visible++;
    });

    if (countEl) countEl.textContent = `${visible} hilo${visible !== 1 ? 's' : ''}`;
    if (emptyEl) emptyEl.hidden = visible > 0;
  }

  searchEl?.addEventListener('input', applyFilters);

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      activeFilter = btn.dataset.filter ?? '';
      applyFilters();
    });
  });
</script>
