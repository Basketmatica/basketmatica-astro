---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'archivo-basketmatica');
if (!page) throw new Error('Falta src/content/pages/archivo-basketmatica.md');
const { Content } = await render(page);
const { title, description, heroImage, heroAlt } = page.data;
---
<BaseLayout wide title={title} description={description} image={heroImage?.src}>
  <article>
    <h1>{title}</h1>
    {heroImage && (
      <Image class="hero-img" src={heroImage} alt={heroAlt || title} widths={[480, 760, 1080]} sizes="(max-width: 1080px) 100vw, 1080px" />
    )}
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>
