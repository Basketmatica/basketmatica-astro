---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroImg from '../assets/blog/generador-de-reportes-de-la-nba/dfb0583a-a603-47b4-b8f9-5f7c319cbdb6.webp';

const title = 'Generador de Reportes de la NBA';
const description =
  'Herramienta gratuita: introduce el nombre de un jugador de la NBA y obtén un scouting report en PDF con datos avanzados y análisis de IA.';
---
<BaseLayout title={title} description={description} image={heroImg.src}>
  <article class="generador">
    <Image class="hero-img" src={heroImg} alt="Generador de Reportes de la NBA" widths={[480, 760, 1080]} sizes="(max-width: 760px) 100vw, 760px" />

    <h1>{title}</h1>

    <div class="prose">
      <p>
        <strong>Generador de Reportes NBA</strong>: una herramienta gratuita para analistas, entrenadores y
        aficionados. Introduce el nombre de cualquier jugador actual y obtendrás un informe detallado en PDF que incluye:
      </p>
      <ul>
        <li><strong>Datos básicos y perfil del jugador.</strong></li>
        <li><strong>Estadísticas actuales e históricas del jugador</strong>, tanto métricas simples como compuestas.</li>
        <li><strong>Análisis FODA</strong> (Fortalezas, Oportunidades, Debilidades y Amenazas) respaldado por métricas avanzadas.</li>
        <li><strong>Comparación con jugadores de perfil y trayectorias similares.</strong></li>
      </ul>
    </div>

    <section class="report-form-container">
      <h2>Genera tu reporte de jugador</h2>
      <form id="pdf-form">
        <label for="playerName">Nombre del jugador</label>
        <input type="text" id="playerName" name="playerName" placeholder="Ej. Stephen Curry" required />
        <button type="submit">Generar PDF</button>
        <p id="status" role="status" aria-live="polite"></p>
      </form>
    </section>

    <p class="note">
      <strong>¡Importante!</strong> Los informes se generan mediante modelos de IA, por lo que pueden existir ligeras
      variaciones de formato. El contenido analítico mantiene su calidad y rigor en todos los casos.
    </p>
  </article>
</BaseLayout>

<style>
  .generador { max-width: 760px; margin-inline: auto; }
  .generador h1 { margin-top: 1.2rem; }

  .report-form-container {
    max-width: 520px;
    margin: 2.5rem auto;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 4px 16px rgba(212, 175, 55, 0.18);
  }
  .report-form-container h2 { margin: 0 0 1rem; text-align: center; }
  .report-form-container label { display: block; margin-bottom: 0.4rem; font-weight: 600; }
  .report-form-container input[type='text'] {
    width: 100%;
    padding: 0.6rem 0.8rem;
    margin-bottom: 1rem;
    border: 1px solid #ccc;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
  }
  .report-form-container button {
    width: 100%;
    padding: 0.75rem;
    background-color: #d4af37;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }
  .report-form-container button:hover { background-color: #b8932f; transform: scale(1.02); }
  .report-form-container button:disabled { background-color: #e0e0e0; color: #999; cursor: not-allowed; transform: none; }
  #status { margin-top: 1rem; font-size: 0.9rem; color: var(--muted); min-height: 1.2em; }

  .note {
    font-size: 0.92rem;
    background: #fff9e6;
    padding: 1rem;
    border-left: 4px solid #d4af37;
    border-radius: 6px;
    color: #5c4a12;
  }

  .spinner {
    display: inline-block;
    width: 20px; height: 20px;
    border: 3px solid rgba(255, 255, 255, 0.4);
    border-top: 3px solid #fff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    vertical-align: middle;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  const API = 'https://reportgeneratornba.onrender.com';

  const form = document.getElementById('pdf-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('playerName') as HTMLInputElement;
    const status = document.getElementById('status') as HTMLParagraphElement;
    const button = form.querySelector('button') as HTMLButtonElement;
    const playerName = input.value.trim();

    if (!playerName) {
      alert('Por favor, introduce un nombre válido.');
      return;
    }

    const originalText = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner"></span>';

    try {
      // Despierta el servidor de Render (puede estar dormido) y deja margen de calentamiento
      status.textContent = 'Generando informe...';
      await fetch(`${API}/`);
      await new Promise((resolve) => setTimeout(resolve, 5000));

      const response = await fetch(`${API}/generate-pdf/?player_name=${encodeURIComponent(playerName)}`);

      if (!response.ok) {
        let message = 'Error al generar el PDF.';
        try {
          const errorData = await response.json();
          if (errorData.detail) message = errorData.detail;
        } catch {
          if (response.status === 404) message = 'Jugador no encontrado. Verifica el nombre.';
          else if (response.status === 500) message = 'Error interno del servidor.';
        }
        throw new Error(message);
      }

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${playerName}_Report.pdf`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      window.URL.revokeObjectURL(url);

      status.textContent = '✅ Informe generado correctamente.';
    } catch (error) {
      status.textContent = '❌ Error generando el informe. Revise la ortografía o inténtelo de nuevo más adelante.';
      console.error(error);
    } finally {
      button.disabled = false;
      button.innerHTML = originalText;
    }
  });
</script>
