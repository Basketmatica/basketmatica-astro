---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORIES } from '../../content.config';
import { categorySlug, categoryFromSlug } from '../../lib/urls';

export async function getStaticPaths() {
  const posts = await getCollection('articulos', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { categoria: categorySlug(category) },
    props: {
      category,
      posts: posts
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { categoria } = Astro.params;
const { category, posts } = Astro.props;
---
<BaseLayout
  wide
  title={category}
  description={`Entradas de la categoría ${category} en Basketmática.`}
>
  <section class="articles-header">
    <p class="post-meta"><a href="/articulos/">Artículos</a> / {category}</p>
    <h1>{category}</h1>
    <p class="intro">{posts.length} {posts.length === 1 ? 'entrada' : 'entradas'}.</p>
    <nav class="cat-filters" aria-label="Filtrar por categoría">
      <a href="/articulos/">Todos</a>
      {CATEGORIES.map((cat) => (
        <a
          href={`/articulos/${categorySlug(cat)}/`}
          aria-current={cat === category ? 'page' : undefined}
        >{cat}</a>
      ))}
    </nav>
  </section>
  <ul class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </ul>
</BaseLayout>

<style>
  .articles-header { padding-block: 2rem 1rem; }

  .cat-filters {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-top: 1.2rem;
  }
  .cat-filters a {
    display: inline-block;
    padding: .3rem .85rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: .85rem;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    background: var(--surface);
    transition: border-color .15s, color .15s;
  }
  .cat-filters a:hover,
  .cat-filters a[aria-current="page"] {
    border-color: var(--brand);
    color: var(--brand);
    background: var(--bg);
  }
</style>
