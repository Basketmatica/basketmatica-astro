---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const page = await getEntry('pages', 'sobre-mi');
if (!page) throw new Error('Falta src/content/pages/sobre-mi.md');
const { Content } = await render(page);
const { title, description, heroImage, heroAlt } = page.data;
---
<BaseLayout title={title} description={description} image={heroImage?.src}>
  <article>
    <h1>{title}</h1>
    {heroImage && (
      <Image class="hero-img" src={heroImage} alt={heroAlt || title} widths={[480, 760, 1080]} sizes="(max-width: 760px) 100vw, 760px" />
    )}
    <div class="prose"><Content /></div>
    <SocialLinks />
  </article>
</BaseLayout>
