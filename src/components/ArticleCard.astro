---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { postPath, formatDate, categorySlug } from '../lib/urls';

interface Props {
  post: CollectionEntry<'articulos'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, heroImage, heroAlt } = post.data;
const href = postPath(post);
---
<article class="article-card">
  {heroImage && (
    <a href={href} class="card-img-wrap" aria-hidden="true" tabindex="-1">
      <Image
        class="card-img"
        src={heroImage}
        alt={heroAlt || title}
        widths={[360, 520]}
        sizes="(max-width: 620px) 100vw, (max-width: 1080px) 50vw, 360px"
      />
    </a>
  )}
  <div class="card-body">
    <p class="post-meta">
      <a class="badge" href={`/articulos/${categorySlug(category)}/`}>{category}</a>
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    </p>
    <h2 class="card-title"><a href={href}>{title}</a></h2>
    <p class="card-desc">{description}</p>
    <a class="card-read" href={href}>Leer →</a>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: border-color .2s, box-shadow .2s;
  }
  .article-card:hover {
    border-color: var(--brand);
    box-shadow: 0 4px 20px rgba(88,60,20,.12);
  }

  .card-img-wrap { display: block; overflow: hidden; aspect-ratio: 16/9; }
  .card-img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s; display: block; }
  .card-img-wrap:hover .card-img { transform: scale(1.03); }

  .card-body { padding: 1.25rem; display: flex; flex-direction: column; gap: .4rem; flex: 1; }

  .card-title { margin: .15rem 0 0; font-size: 1.1rem; line-height: 1.3; }
  .card-title a { color: var(--brand); text-decoration: none; }
  .card-title a:hover { color: var(--accent-600); }

  .card-desc { margin: 0; color: var(--ink-soft); font-size: .93rem; line-height: 1.55; flex: 1; }

  .card-read {
    align-self: flex-start;
    margin-top: .4rem;
    font-family: var(--font-display);
    font-size: .87rem;
    font-weight: 600;
    color: var(--accent-600);
    text-decoration: none;
  }
  .card-read:hover { color: var(--accent); }
</style>
