---
export type ToolStatus = 'Disponible' | 'Beta' | 'Próximamente';

interface Props {
  title: string;
  description: string;
  status: ToolStatus;
  href: string;
  icon?: string;
}

const { title, description, status, href, icon } = Astro.props;
const available = status !== 'Próximamente';
---

<article class="tool-card">
  {icon && <div class="tool-icon" aria-hidden="true">{icon}</div>}
  <div class="tool-body">
    <header class="tool-header">
      <h2 class="tool-title">{title}</h2>
      <span class:list={["tool-badge", `tool-badge--${status === 'Disponible' ? 'disponible' : status === 'Beta' ? 'beta' : 'soon'}`]}>
        {status}
      </span>
    </header>
    <p class="tool-desc">{description}</p>
    {available
      ? <a class="tool-cta" href={href}>Abrir herramienta →</a>
      : <span class="tool-cta tool-cta--disabled">Próximamente</span>
    }
  </div>
</article>

<style>
  .tool-card {
    display: flex;
    gap: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    transition: box-shadow .2s, border-color .2s;
  }
  .tool-card:hover { border-color: var(--brand); box-shadow: 0 4px 20px rgba(88,60,20,.12); }

  .tool-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: .15rem;
  }
  .tool-body { display: flex; flex-direction: column; gap: .7rem; flex: 1; }

  .tool-header { display: flex; align-items: center; flex-wrap: wrap; gap: .6rem; }
  .tool-title {
    font-size: 1.2rem;
    margin: 0;
    color: var(--brand);
  }

  .tool-badge {
    font-family: var(--font-display);
    font-size: .72rem;
    font-weight: 700;
    padding: .15rem .55rem;
    border-radius: 999px;
    letter-spacing: .03em;
    text-transform: uppercase;
  }
  .tool-badge--disponible { background: #d4f0e8; color: #176B5A; }
  .tool-badge--beta       { background: #fef3c7; color: #92400e; }
  .tool-badge--soon       { background: var(--bg);  color: var(--ink-soft); border: 1px solid var(--line); }

  .tool-desc { margin: 0; color: var(--ink-soft); font-size: .97rem; line-height: 1.55; }

  .tool-cta {
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: .9rem;
    font-weight: 600;
    color: var(--accent-600);
    text-decoration: none;
  }
  .tool-cta:hover { color: var(--accent); }
  .tool-cta--disabled { color: var(--ink-soft); cursor: default; }
</style>
