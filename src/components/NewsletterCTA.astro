---
import { NEWSLETTER_URL } from '../consts';
---
<section class="newsletter-cta">
  <p class="newsletter-label">Newsletter · Basketmática</p>
  <h2 class="newsletter-title">El análisis, en tu bandeja</h2>
  <p class="newsletter-sub">
    Cada mes, un análisis de datos que no encontrarás en ningún otro sitio.
    Para aficionados, entrenadores y periodistas que quieren entender el juego con datos.
  </p>
  <a class="newsletter-btn" href={NEWSLETTER_URL} target="_blank" rel="noopener">
    Suscribirme gratis →
  </a>
  <p class="newsletter-note">Gratis. Cancela cuando quieras.</p>
</section>

<style>
  .newsletter-cta {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    margin: 2rem 0 3rem;
    box-shadow: var(--shadow);
  }

  .newsletter-label {
    font-family: var(--font-display);
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent-600);
    margin: 0 0 .8rem;
  }

  .newsletter-title {
    font-size: 1.75rem;
    margin: 0 0 .7rem;
    color: var(--brand);
  }

  .newsletter-sub {
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 460px;
    margin: 0 auto 1.8rem;
  }

  .newsletter-btn {
    display: inline-block;
    padding: .75rem 1.8rem;
    margin: 0 auto 1rem;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background .2s, transform .15s;
  }
  .newsletter-btn:hover { background: var(--accent-600); color: #fff; transform: translateY(-1px); }

  .newsletter-note { font-size: .84rem; color: var(--ink-soft); margin: 0; }

  @media (max-width: 500px) {
    .newsletter-btn { display: block; width: 100%; box-sizing: border-box; text-align: center; }
    .newsletter-cta { padding: 2rem 1.25rem; }
  }
</style>
