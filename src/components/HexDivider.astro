---
interface Props { class?: string; }
const { class: className } = Astro.props;
const uid = 'hex-' + Math.random().toString(36).slice(2, 8);
---
<div class:list={["hex-divider", className]} role="presentation" aria-hidden="true">
  <svg width="100%" height="16" viewBox="0 0 280 16" preserveAspectRatio="xMidYMid meet">
    <defs>
      <pattern id={uid} width="28" height="16" patternUnits="userSpaceOnUse">
        <path d="M9 1 L19 1 L24 8 L19 15 L9 15 L4 8 Z" fill="none" stroke="currentColor" stroke-width="1" />
      </pattern>
    </defs>
    <rect width="280" height="16" fill={`url(#${uid})`} />
  </svg>
</div>

<style>
  .hex-divider { color: var(--brand); opacity: .22; margin: 2.5rem 0; line-height: 0; }
</style>
